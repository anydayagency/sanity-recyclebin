{
  "name": "sanity-plugin-recycle-bin",
  "version": "1.0.0",
  "description": "Sanity plugin providing soft-delete functionality with 30-day retention and document restoration",
  "keywords": [
    "sanity",
    "sanity-plugin",
    "recycle-bin",
    "soft-delete",
    "trash",
    "document-recovery"
  ],
  "license": "MIT",
  "author": "Anyday Agency",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react,react-dom,sanity,@sanity/ui,@sanity/icons",
    "dev": "tsup src/index.ts --format esm,cjs --watch --dts --external react,react-dom,sanity,@sanity/ui,styled-components,@sanity/icons",
    "prepublishOnly": "npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@sanity/icons": "^3",
    "@sanity/ui": "^3",
    "react": "^18 || ^19",
    "sanity": "^5"
  },
  "devDependencies": {
    "@sanity/icons": "^3.7.0",
    "@sanity/ui": "^3.0.0",
    "tsup": "^8.4.0",
    "@types/react": "^19.1",
    "eslint": "^8.57.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanity": "^5.7.0",
    "styled-components": "^6.1.18",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18"
  },
  "sanityPlugin": {
    "verifyPackage": {
      "module": false
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/anydayagency/sanity-recyclebin"
  },
  "bugs": {
    "url": "https://github.com/anydayagency/sanity-recyclebin/issues"
  },
  "homepage": "https://github.com/anydayagency/sanity-recyclebin#readme"
}
